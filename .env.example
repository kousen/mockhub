# MockHub Environment Variables
# Copy to .env and fill in values for local development.
# Variables with defaults shown after := are optional.

# ─── Profiles ───────────────────────────────────────────────
# dev: PostgreSQL, mock payment, mock SMS/email, AI disabled
# Add ai-anthropic (or ai-openai, ai-ollama) to enable AI features
SPRING_PROFILES_ACTIVE=dev

# ─── Database (dev profile) ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mockhub
DB_USERNAME=mockhub
DB_PASSWORD=mockhub_dev

# ─── Database (prod profile) ────────────────────────────────
# Railway's DATABASE_URL format is incompatible with JDBC — use these instead
# SPRING_DATASOURCE_URL=jdbc:postgresql://host:port/dbname
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=

# ─── Security (REQUIRED) ───────────────────────────────────
# Must be valid Base64 strings, at least 256 bits
JWT_SECRET=
TICKET_SIGNING_SECRET=

# ─── Security (optional) ───────────────────────────────────
# COOKIE_SECURE=false              # Set true in production (HTTPS)
# CORS_ORIGINS=http://localhost:5173

# ─── AI Providers (pick one, requires matching profile) ─────
# Profile: ai-anthropic
# ANTHROPIC_API_KEY=

# Profile: ai-openai
# OPENAI_API_KEY=

# ─── AI Eval ────────────────────────────────────────────────
# MOCKHUB_EVAL_AI_JUDGE_ENABLED=false  # Enable AI-as-judge eval conditions

# ─── MCP / ACP ─────────────────────────────────────────────
# IMPORTANT: Change from default in production — the default key is public
# MCP_API_KEY=mockhub-dev-key      # API key for MCP and ACP endpoints

# ─── Stripe (profile: stripe) ──────────────────────────────
# Not needed with mock-payment profile (default in dev)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Twilio SMS (profile: sms-twilio) ──────────────────────
# Not needed with mock-sms profile (default in dev)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Email (profile: email-resend or email-smtp) ───────────
# Not needed with mock-email profile (default in dev)
# RESEND_API_KEY=                  # For email-resend profile
# EMAIL_FROM_ADDRESS=noreply@mockhub.dev

# ─── Ticket Delivery ───────────────────────────────────────
# TICKET_VERIFICATION_URL=http://localhost:8080
# SMS_ORDER_BASE_URL=http://localhost:5173

# ─── File Storage ───────────────────────────────────────────
# Note: StorageConfig reads mockhub.storage.location, not this var.
# To change the upload path, set it in application.yml or as a system property.
# Default: ./uploads

# ─── Production ─────────────────────────────────────────────
# PORT=8080                        # Railway sets this automatically
